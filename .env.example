# Required. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TH_ENC_KEY=

# Timezone used for Garmin pulls and daily boundaries.
TH_TZ=UTC

# Poll cadence for scheduled Sync operations.
TH_SYNC_INTERVAL_MINUTES=180

# Local host port mapped to the container's port 8000.
TH_PORT=8000

# SQLite data directory inside the container. Docker Compose mounts a named volume here.
TH_DATA_DIR=/data

# Optional path to a built React app. Empty means auto-detect web/dist.
TH_WEB_DIST=
