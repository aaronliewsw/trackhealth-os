# Required. Generate a key (stdlib only — no extra packages to install):
#   python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# No Python handy? Use openssl instead:
#   openssl rand -base64 32 | tr '+/' '-_'
TH_ENC_KEY=

# Timezone used for Garmin pulls and daily boundaries.
TH_TZ=UTC

# Poll cadence for scheduled Sync operations.
TH_SYNC_INTERVAL_MINUTES=180

# Local host port mapped to the container's port 8000.
TH_PORT=8000

# SQLite data directory. Only used for non-Docker (local) runs. Under Docker the compose
# file fixes this to /data and mounts the named volume there, so changing it here — or
# exporting TH_DATA_DIR in your shell — has no effect on the container.
TH_DATA_DIR=/data

# Optional path to a built React app. Empty means auto-detect web/dist.
TH_WEB_DIST=
